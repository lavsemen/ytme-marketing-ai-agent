{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "outDir": "dist",
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*"]
}
