# ===== Agent (CLI / pipeline) =====
# Copy to .env and fill in values.

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
ANTHROPIC_MODEL=claude-sonnet-4-5

# Tour client
TOUR_CLIENT_MODE=real
YOUTRAVEL_API_BASE_URL=https://youtravel.me
YOUTRAVEL_IMAGE_BASE_URL=https://youtravel.me/
# YOUTRAVEL_API_TOKEN=

# Landing public URL (used in generated posts / meta tags)
LANDING_BASE_URL=https://your-github-user.github.io/ytme-marketing-ai-agent

# Logging
LOG_LEVEL=info

# Firebase Admin SDK (agent CLI + GitHub Actions)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Web SDK config for landing metrics tracker (public-by-design):
# FIREBASE_WEB_API_KEY=AIza...
# FIREBASE_WEB_AUTH_DOMAIN=your-project-id.firebaseapp.com
# FIREBASE_WEB_APP_ID=1:123456789:web:abcdef

# Slack (News2Trip bot) — optional; pipeline sends success/reject notifications
# Bot needs chat:write; open a DM with the bot or invite it to the channel first.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=D0B7WAWLX8D

# ===== Admin SPA (Vite build-time, VITE_ prefix) =====
# Read from this file (or .env.local) when running yarn admin:dev.
# packages/admin/.env.local overrides the same keys if present.

# VITE_REPO_OWNER=your-github-user
# VITE_REPO_NAME=ytme-marketing-ai-agent
# VITE_GENERATE_WORKFLOW_FILE=generate.yml
# VITE_LANDING_BASE_URL=https://your-github-user.github.io/ytme-marketing-ai-agent

# Firebase Web SDK (required for admin UI auth + Firestore)
# VITE_FIREBASE_API_KEY=AIza...
# VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
