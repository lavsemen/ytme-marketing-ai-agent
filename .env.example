# ===== Agent (.env / GitHub Secrets) =====

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
ANTHROPIC_MODEL=claude-sonnet-4-5

# Tour client
TOUR_CLIENT_MODE=real
YOUTRAVEL_API_BASE_URL=https://youtravel.me
YOUTRAVEL_IMAGE_BASE_URL=https://youtravel.me/
# YOUTRAVEL_API_TOKEN=

# Landing public URL (used in generated posts / meta tags)
LANDING_BASE_URL=https://your-github-user.github.io/ytme-marketing-ai-agent

# Logging
LOG_LEVEL=info

# ===== Admin (Vite build-time) =====
# VITE_REPO_OWNER=your-github-user
# VITE_REPO_NAME=ytme-marketing-ai-agent
# VITE_GENERATE_WORKFLOW_FILE=generate.yml
# VITE_LANDING_BASE_URL=https://your-github-user.github.io/ytme-marketing-ai-agent
